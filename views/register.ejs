<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/src/output.css" />
    <title>Sign Up</title>
  </head>
  <body class="flex h-dvh items-center justify-center bg-[#f4f4f4] px-2">
    <main class="text-center">
      <!-- Company Logo container -->
      <div class="space-x-1 flex justify-center items-center">
        <span class="text-2xl font-bold text-[#0A66C2]">Image Globe</span>
        <!-- SVG for logo -->
         <img class="w-7" src="/images/gallery-svgrepo-com.svg" alt="">
      </div>
      <div>
        <h1 class="my-5 text-2xl">Make the most of your professional life</h1>
      </div>
      <!-- Container for Authentication methods -->
      <div class="max-w-100 rounded-xl bg-white px-5 py-10 text-sm">
        <form action="/register" method="post">

          <!-- Display only when redirected if user exists -->
           <% if (duplicateUser) { %>
            <div class="bg-red-200 h-15 w-full text-center text-red-500 font-medium flex justify-center items-center mb-3"><%= error %></div>
           <% } %>

          <!-- Fieldset for signup with local strategy -->
          <fieldset class="flex flex-col space-y-5 text-gray-500">
            <label class="text-left" for="email" class=""
              >E-mail
              <input
                class="mt-2 block h-7 w-full rounded border px-2 focus:border focus:outline-blue-500"
                type="email"
                name="email"
                id="email"
                required
              />
            </label>

            <label class="text-left" for="password"
              >Password (6 characters minimum)
              <input
                class="mt-2 block h-7 w-full rounded border px-2 focus:border focus:outline-blue-500"
                type="password"
                name="password"
                id="password"
                required
              />
            </label>

            <p>
              By clicking Accept and register, your agree to the 
              <span class="font-medium text-blue-600">Terms of Use</span> of the
              <span class="font-medium text-blue-600">Privacy Policy</span> and
              <span class="font-medium text-blue-600">cookies Policy</span>
              of Image Globe.
            </p>
            <button
              class="m-auto h-10 w-80 cursor-pointer rounded-3xl bg-[#0A66C2] font-medium text-white"
              type="submit"
            >
              Accept & Sign Up
            </button>
          </fieldset>
        </form>
        <!-- Fieldset for O Auth Method -->
        <fieldset class="mt-4 border-t border-t-gray-300 text-center">
          <legend class="mb-4 px-3">or</legend>
          <!-- Google sign up button -->
          <a
            class="m-auto mb-4 flex h-10 w-80 cursor-pointer items-center justify-center rounded-3xl border border-[#0A66C2] text-center font-medium text-[#0A66C2] space-x-2"
            href="/auth/google"
            role="button"
          >
          <!-- Google Auth Icon -->
           <img class="w-5" src="/images/google-color-svgrepo-com.svg" alt="">
            <span>Sign up with Google</span>
          </a>

          <!-- Login Alternative if account exists -->
          <p>Already registered? <a href="/login" class="text-blue-600 font-medium">Login</a></p>
        </fieldset>
      </div>
    </main>
  </body>
</html>
